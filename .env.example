# ============================================
# VARIABLES DE ENTORNO - PROYECTO SANTI
# Copia estas variables en Vercel > Settings > Environment Variables
# ============================================

# --- SUPABASE (OBLIGATORIO) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- APP (OBLIGATORIO) ---
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_NAME=SANTI
CENTRO_NOMBRE=Neuropsicología y Terapias SANTI

# --- IA (OBLIGATORIO) ---
GEMINI_API_KEY=tu_gemini_api_key
GROQ_API_KEY=tu_groq_api_key

# --- EMAIL ---
GMAIL_USER=tu_correo@gmail.com
GMAIL_PASS=tu_app_password_gmail

# --- NOTIFICACIONES PUSH ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu_vapid_public_key
VAPID_PRIVATE_KEY=tu_vapid_private_key

# --- GOOGLE CALENDAR (opcional) ---
GOOGLE_CALENDAR_CLIENT_ID=tu_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=tu_client_secret

# --- ELEVENLABS TTS (opcional) ---
ELEVENLABS_API_KEY=tu_api_key
ELEVENLABS_VOICE_ID=tu_voice_id
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- WHATSAPP SERVICE (opcional) ---
WSP_SERVICE_URL=https://tu-servicio-whatsapp.railway.app
WSP_SERVICE_SECRET=tu_secret

# --- TELEGRAM (opcional) ---
TELEGRAM_BOT_TOKEN=tu_bot_token
TELEGRAM_CHAT_ID=tu_chat_id
