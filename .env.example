# ════════════════════════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — jugando-aprendo / SANTI
#  Copiá este archivo como  .env.local  y completá los valores.
#  Las marcadas [OBLIGATORIA] son imprescindibles para que la app arranque.
#  El resto son por-función: si no las ponés, esa función queda desactivada.
# ════════════════════════════════════════════════════════════════════════════

# ── SUPABASE [OBLIGATORIAS] ──────────────────────────────────────────────────
# Panel Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # "service_role" key — ¡SECRETA! nunca en el cliente

# ── URLs DE LA APP [recomendadas] ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000      # en producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SANTI

# ── DATOS DEL CENTRO (membretes, reportes, facturas) ─────────────────────────
CENTRO_NOMBRE=Vanty ABA
CENTER_EMAIL=contacto@tucentro.com
CENTER_PHONE=+000 0000 0000
CENTER_ADDRESS=Dirección del centro
CENTER_RUC=                                     # RUC / identificación fiscal (opcional)

# ── IA (chat ARIA, reportes, análisis) ───────────────────────────────────────
# Gemini → https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq (LLM rápido) → https://console.groq.com/keys
GROQ_API_KEY=
# Hugging Face (embeddings / modelos) → https://huggingface.co/settings/tokens
HF_API_KEY=

# ── EMAIL (elegí UNA opción) ─────────────────────────────────────────────────
# Opción A: Resend → https://resend.com/api-keys
RESEND_API_KEY=
# Opción B: Gmail SMTP (contraseña de aplicación, NO tu clave normal)
GMAIL_USER=
GMAIL_PASS=

# ── NOTIFICACIONES PUSH (Web Push / PWA) ─────────────────────────────────────
# Generá el par con:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── RATE LIMITING (opcional — sin esto usa memoria local) ────────────────────
# Upstash Redis → https://console.upstash.com  (recomendado en producción)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── WHATSAPP (microservicio aparte en /wsp-service) ──────────────────────────
WSP_SERVICE_URL=
WSP_SERVICE_SECRET=

# ── TELEGRAM (alertas internas, opcional) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CALENDARIOS (sincronización de agenda, opcional) ─────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── CIE-11 / OMS (diagnósticos, opcional) ────────────────────────────────────
# https://icd.who.int/icdapi
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=

# ── SECRETOS INTERNOS (cron jobs y auditoría) ────────────────────────────────
CRON_SECRET=                                    # string aleatorio largo
AUDIT_SECRET=                                   # string aleatorio largo

# ── STORAGE / VOZ (opcional) ─────────────────────────────────────────────────
KNOWLEDGE_BUCKET_NAME=knowledge                 # nombre del bucket de la base de conocimiento
EDGE_TTS_VOICE=es-MX-DaliaNeural
EDGE_TTS_VERSION=
