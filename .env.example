# ═══════════════════════════════════════════════════════════════
# PLANTILLA .env.local — Neuropsicología y Terapias SANTI
# ═══════════════════════════════════════════════════════════════
#
# IMPORTANTE: Este archivo está en .gitignore — NUNCA se sube a
# GitHub. Rellena los valores y úsalo solo localmente.
# Para producción, copia estos valores en Vercel → Settings →
# Environment Variables.
#
# ═══════════════════════════════════════════════════════════════

# ───── IDENTIDAD DEL CENTRO ─────
NEXT_PUBLIC_APP_NAME=
CENTRO_NOMBRE=
NEXT_PUBLIC_APP_URL=

# ───── DATOS FISCALES ─────
CENTER_RUC=
CENTER_ADDRESS=
CENTER_PHONE=
CENTER_EMAIL=

# ───── SUPABASE (crear proyecto nuevo) ─────
# https://supabase.com → New Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───── IA (Groq) ─────
# https://console.groq.com → API Keys
GROQ_API_KEY=

# ───── IA (Gemini) — para procesar PDFs ─────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ───── VOZ IA (ElevenLabs) — opcional ─────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# ───── EMAIL (Gmail SMTP) — opcional ─────
# Gmail del centro + contraseña de aplicación de 16 caracteres
# https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_PASS=

# ───── WHATSAPP (Railway) — opcional ─────
# URL del microservicio en Railway + secreto compartido
WSP_SERVICE_URL=
WSP_SERVICE_SECRET=

# ───── SECRETOS INTERNOS ─────
# Generar con: openssl rand -hex 32
AUDIT_SECRET=
CRON_SECRET=

# ───── NOTIFICACIONES PUSH (VAPID) ─────
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ───── GOOGLE CALENDAR — opcional ─────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ───── MICROSOFT CALENDAR — opcional ─────
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ───── WHO ICD-11 (diagnósticos) — opcional ─────
WHO_ICD_CLIENT_ID=
WHO_ICD_CLIENT_SECRET=

# ───── TELEGRAM — opcional ─────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
